# Required: OpenAI API key (or compatible endpoint)
OPENAI_API_KEY=sk-your-key-here

# Optional: use a compatible API (Ollama, LM Studio, etc.)
# OPENAI_BASE_URL=http://localhost:11434/v1
# OPENAI_MODEL=gpt-4o-mini

# Server
PORT=3001
JARVIS_WORKSPACE=/path/to/allowed/directory

# Safety: require approval for destructive operations (default: true)
JARVIS_REQUIRE_APPROVAL=true
