{
  "name": "jarvis",
  "version": "1.0.0",
  "description": "JARVIS-like AI assistant that controls your computer",
  "type": "module",
  "bin": {
    "jarvis": "./dist/cli.js"
  },
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:server": "tsx watch src/server.ts",
    "build": "tsc && npm run build:web",
    "build:web": "cd web && npm run build",
    "prestart": "node scripts/ensure-web-built.mjs",
    "start": "node dist/server.js",
    "setup": "npm install && cp -n .env.example .env 2>/dev/null || true && npm run build",
    "cli": "tsx src/cli.ts",
    "postinstall": "cd web && npm install"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "openai": "^4.77.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/node": "^20.17.10",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
